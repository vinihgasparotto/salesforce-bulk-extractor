# ── Auth method ───────────────────────────────────────────────────────────────
# "password" = username + password + security token (no Connected App needed)
# "oauth"    = browser-based OAuth flow (requires a Salesforce Connected App)
SF_AUTH_METHOD=password

SF_LOGIN_URL=https://login.salesforce.com
SF_API_VERSION=59.0
SF_OUTPUT_DIR=output

# ── Password auth (SF_AUTH_METHOD=password) ───────────────────────────────────
SF_USERNAME=you@example.com
SF_PASSWORD=yourpassword
SF_SECURITY_TOKEN=yourtoken   # leave blank if your IP is trusted in Salesforce

# ── OAuth auth (SF_AUTH_METHOD=oauth) ─────────────────────────────────────────
# Requires a Connected App with callback URL: http://localhost:8080/callback
# and scopes: api, refresh_token, offline_access
SF_CLIENT_ID=
SF_CLIENT_SECRET=
SF_CALLBACK_PORT=8080
